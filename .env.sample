# === VideoDB ===
VIDEO_DB_API_KEY=your_videodb_api_key_here
VIDEO_DB_BASE_URL=https://api.videodb.io

# === OpenAI ===
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # optional: custom endpoint

# === Search Tuning (optional) ===
# SCORE_THRESHOLD=0                  # minimum score for search results (0 = no threshold)
# DYNAMIC_SCORE_PERCENTAGE=100       # percentage of dynamic score range to use

# === Database (optional) ===
# DEEPSEARCH_DB_PATH=~/.deepsearch/deepsearch.db  # SQLite database path
